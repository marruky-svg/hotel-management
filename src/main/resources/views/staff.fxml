<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>

<?import javafx.scene.control.TableColumn?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.marruky.ui.controllers.StaffController"
            prefHeight="600.0" prefWidth="900.0">

    <!-- Topo -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10;">
            <Label text="Hotel Management — Staff" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <!-- Esquerda — botões -->
    <left>
        <VBox spacing="10" style="-fx-padding: 10;">
            <Button text="List Reservations" onAction="#handleListReservations" maxWidth="Infinity"/>
            <Button text="Confirm Reservation" onAction="#handleConfirmReservation" maxWidth="Infinity"/>
            <Button text="Check-in" onAction="#handleCheckIn" maxWidth="Infinity"/>
            <Button text="Check-out" onAction="#handleCheckOut" maxWidth="Infinity"/>
            <Button text="Add Service" onAction="#handleAddService" maxWidth="Infinity"/>
            <Button text="Issue Invoice" onAction="#handleIssueInvoice" maxWidth="Infinity"/>
            <Button text="View Invoice" onAction="#handleViewInvoice" maxWidth="Infinity"/>
            <Button text="Logout" onAction="#handleLogout" maxWidth="Infinity"/>
        </VBox>
    </left>

    <!-- Centro — tabela -->
    <center>
        <TableView fx:id="reservationsTable" style="-fx-padding: 10;">
            <columns>
                <TableColumn text="ID" fx:id="idColumn" prefWidth="50"/>
                <TableColumn text="Client" fx:id="clientIdColumn" prefWidth="80"/>
                <TableColumn text="Room" fx:id="roomIdColumn" prefWidth="80"/>
                <TableColumn text="Check-in" fx:id="checkInColumn" prefWidth="120"/>
                <TableColumn text="Check-out" fx:id="checkOutColumn" prefWidth="120"/>
                <TableColumn text="State" fx:id="stateColumn" prefWidth="120"/>
            </columns>
        </TableView>
    </center>

</BorderPane>